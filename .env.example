# === NestSeek Configuration ===

# Server
PORT=3000
APP_URL=http://localhost:3000

# JWT Secret - CHANGE THIS IN PRODUCTION (use a long random string)
JWT_SECRET=your-secret-key-change-in-production

# Email via Brevo (free: 300 emails/day)
# 1. Sign up at https://app.brevo.com/
# 2. Go to Settings > SMTP & API > SMTP tab
# 3. Copy your SMTP credentials below
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login-email@example.com
SMTP_PASS=your-brevo-smtp-key
FROM_EMAIL=noreply@nestseek.ie
